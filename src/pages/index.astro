import { readFileSync } from 'fs';
import { join } from 'path';
import { parse } from 'yaml';
import { getEntry } from 'astro:content';
import { makeT } from '../scripts/t';
import HomePage from '../components/HomePage.astro';

// --- Config ---
const langConfig    = await getEntry('languages', 'languages');
let profileConfig = null;
try { profileConfig = await getEntry('profiles', 'profiles'); } catch {}

const translations  = await getEntry('i18n', 'translations');

const defaultLang    = langConfig?.data?.default ?? 'en';
const defaultProfile = profileConfig?.data?.profiles?.find(p => p.slug === '') ?? { id: 'default', slug: '', spec: null };
const profile = defaultProfile.slug;

const t = makeT(translations?.data ?? {}, defaultLang);

// --- CV data from merged artifact ---
const cvFileName = defaultProfile.spec ? `${defaultLang}_${defaultProfile.spec}.yaml` : `${defaultLang}.yaml`;
const cvPath = join(process.cwd(), 'public/cv', cvFileName);
const data = parse(readFileSync(cvPath, 'utf8'));

// --- URLs ---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const specSuffix = defaultProfile.spec ? `_${defaultProfile.spec}` : '';
const pdfUrl  = `${base}/downloads/resume_${defaultLang}${specSuffix}.pdf`;
const docxUrl = `${base}/downloads/resume_${defaultLang}${specSuffix}.docx`;
const txtUrl  = `${base}/downloads/resume_${defaultLang}${specSuffix}.txt`;
---

<HomePage
  lang={defaultLang}
  data={data}
  pdfUrl={pdfUrl}
  docxUrl={docxUrl}
  txtUrl={txtUrl}
  profile={profile}
  t={{
    nameFallback:     t('cv.unnamed'),
    contacts:         t('cv.contacts'),
    skills:           t('cv.skills'),
    experience:       t('cv.experience'),
    achievements:     t('cv.achievements'),
    education:        t('cv.education'),
    downloads:        t('cv.download'),
    company:          t('cv.company_fallback'),
    empty_skills:     t('cv.empty_skills'),
    empty_experience: t('cv.empty_experience'),
  }}
/>