import { readFileSync, existsSync } from 'fs';
import { join } from 'path';
import { parse } from 'yaml';
import { getEntry } from 'astro:content';
import { makeT } from '../scripts/t';
import HomePage from '../components/HomePage.astro';

export async function getStaticPaths() {
  const langConfig    = await getEntry('languages', 'languages');
  let profileConfig = null;
  try { profileConfig = await getEntry('profiles', 'profiles'); } catch {}

  const defaultLang = langConfig?.data?.default ?? 'en';
  const langs       = langConfig?.data?.languages ?? [];
  const profiles    = profileConfig?.data?.profiles ?? [{ id: 'default', slug: '', spec: null }];

  const paths = [];

  for (const profile of profiles) {
    for (const lang of langs) {
      // default profile + default lang → / (handled by index.astro, skip)
      if (profile.slug === '' && lang.id === defaultLang) continue;

      // build slug segments
      const segments = [];
      if (profile.slug) segments.push(profile.slug);
      if (lang.id !== defaultLang) segments.push(lang.id);

      paths.push({
        params: { slug: segments.join('/') },
        props:  { profileData: profile, langId: lang.id },
      });
    }
  }

  return paths;
}

const { profileData, langId } = Astro.props;

// --- Translations ---
const translations = await getEntry('i18n', 'translations');
const t = makeT(translations?.data ?? {}, langId);

// --- CV data from merged artifact ---
const cvFileName = profileData.spec
  ? `${langId}_${profileData.spec}.yaml`
  : `${langId}.yaml`;
const cvPath = join(process.cwd(), 'public/cv', cvFileName);

let data = {};
if (existsSync(cvPath)) {
  data = parse(readFileSync(cvPath, 'utf8'));
} else {
  const fallbackPath = join(process.cwd(), 'public/cv', `${langId}.yaml`);
  if (existsSync(fallbackPath)) {
    data = parse(readFileSync(fallbackPath, 'utf8'));
  }
}

// --- URLs ---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const specSuffix = profileData.spec ? `_${profileData.spec}` : '';
const pdfUrl  = `${base}/downloads/resume_${langId}${specSuffix}.pdf`;
const docxUrl = `${base}/downloads/resume_${langId}${specSuffix}.docx`;
const txtUrl  = `${base}/downloads/resume_${langId}${specSuffix}.txt`;
---

<HomePage
  lang={langId}
  data={data}
  pdfUrl={pdfUrl}
  docxUrl={docxUrl}
  txtUrl={txtUrl}
  profile={profileData.slug}
  t={{
    nameFallback:     t('cv.unnamed'),
    contacts:         t('cv.contacts'),
    skills:           t('cv.skills'),
    experience:       t('cv.experience'),
    achievements:     t('cv.achievements'),
    downloads:        t('cv.download'),
    education:        t('cv.education'),
    company:          t('cv.company_fallback'),
    empty_skills:     t('cv.empty_skills'),
    empty_experience: t('cv.empty_experience'),
  }}
/>