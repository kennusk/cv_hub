import fs from 'node:fs';
import path from 'node:path';
import { getEntry } from 'astro:content';
import Layout from '../../components/Layout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { makeT } from '../../scripts/t';

const MEDIA_DIR = path.join(process.cwd(), 'public/media/projects');

function toPrefix(slug: string) {
  return slug.replace(/-/g, '_');
}

function getSlugsWithYaml(langIds: string[]): string[] {
  if (!fs.existsSync(MEDIA_DIR)) return [];
  return fs.readdirSync(MEDIA_DIR).filter((name) => {
    const dir    = path.join(MEDIA_DIR, name);
    const prefix = toPrefix(name);
    if (!fs.statSync(dir).isDirectory()) return false;
    return langIds.some((l) => fs.existsSync(path.join(dir, `${prefix}_${l}.yaml`)));
  });
}

const langCfg      = await getEntry('languages', 'languages');
const defaultLang: string = langCfg?.data?.default ?? 'en';
const allLangs: { id: string; label: string }[] = langCfg?.data?.languages ?? [];
const langIds      = allLangs.map((l) => l.id);
const base         = import.meta.env.BASE_URL.replace(/\/$/, '');

const translations = await getEntry('i18n', 'translations');
const t = makeT(translations?.data ?? {}, defaultLang);

let projects: any[] = [];
try {
  const entry = await getEntry('showcase', 'projects');
  projects = entry?.data?.projects ?? [];
} catch {}

projects = [...projects].sort((a, b) => {
  const ao = Number.isFinite(Number(a?.order)) ? Number(a.order) : 9999;
  const bo = Number.isFinite(Number(b?.order)) ? Number(b.order) : 9999;
  if (ao !== bo) return ao - bo;
  return String(a?.name ?? '').toLowerCase().localeCompare(String(b?.name ?? '').toLowerCase());
});

const projectSlugsWithPages = new Set(getSlugsWithYaml(langIds));

const showcaseLangLinks = allLangs.map(l => ({
  id:     l.id,
  label:  l.label,
  href:   l.id === defaultLang ? `${base}/showcase` : `${base}/showcase/${l.id}`,
  active: l.id === defaultLang,
}));
---

<Layout title={t('showcase.page_title')} lang={defaultLang} section="showcase" profile="" customLangLinks={showcaseLangLinks}>
  <section class="container">
    <header class="showcase__header">
      <!-- <h1>{t('showcase.title')}</h1> -->
    </header>

    {projects.length === 0 && (
      <article class="card"><p class="muted">{t('showcase.empty')}</p></article>
    )}

    {projects.length > 0 && (
      <div class="showcase__section">
        <div class="grid">
          {projects
            .map((p: any) => (
              <ProjectCard
                project={p}
                lang={defaultLang}
                hasCasePage={projectSlugsWithPages.has(p.slug ?? '')}
                base={base}
                defaultLang={defaultLang}
              />
            ))}
        </div>
      </div>
    )}
  </section>
</Layout>

<style>
  .showcase__header { margin-bottom: 24px; }
  .showcase__header h1 { margin: 0; }
  .showcase__section { margin-bottom: 14px; }
</style>