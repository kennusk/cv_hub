---
import LanguageSwitch from './LanguageSwitch.astro';
const { lang = 'en' } = Astro.props;
---

<header class="header">
  <div class="container header__row">
    <a class="brand" href={`/?lang=${lang}`}>CV Hub</a>

    <nav class="nav">
      <a href={`/?lang=${lang}`}>{lang === 'ru' ? 'Главная' : 'Home'}</a>
      <a href={`/showcase?lang=${lang}`}>{lang === 'ru' ? 'Шоукейс' : 'Showcase'}</a>
    </nav>

    <LanguageSwitch lang={lang} />
  </div>
</header>