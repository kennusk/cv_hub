---
//
//  Layout.astro
//  CV Hub
//
//  Created by Alexander Gusarov on 03.03.2026.
//  @spartan121
//
import '../styles/global.css';
import AnimatedBackground from './AnimatedBackground.astro';
import { getEntry } from 'astro:content';
import { makeT } from '../scripts/t';

// Change theme here
//
//import '../styles/themes/vscode.css';
//
// Change theme here

const {
  title = 'CV Hub',
  lang = 'en',
  section = 'main',
  profile = '',
  description,
  ogImage,
} = Astro.props;

// --- Config ---
const langConfig    = await getEntry('languages', 'languages');
let profileConfig = null;
try { profileConfig = await getEntry('profiles', 'profiles'); } catch {}
const translations  = await getEntry('i18n', 'translations');

const defaultLang = langConfig?.data?.default ?? 'en';
const allLangs    = langConfig?.data?.languages ?? [];
const allProfiles = profileConfig?.data?.profiles ?? [];
const t = makeT(translations?.data ?? {}, lang);

// --- Meta ---
const repo = import.meta.env.GITHUB_REPOSITORY;
const [owner] = repo ? repo.split('/') : [null, null];
const siteUrl = owner
  ? `https://${owner}.github.io/`
  : 'http://localhost:4321';

const metaDescription = description ?? t('meta.description');
const metaImage = ogImage ?? `${siteUrl}/og-image.png`;
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// --- Navigation ---
function buildHref(profileSlug: string, langId: string): string {
  const segments = [];
  if (profileSlug) segments.push(profileSlug);
  if (langId !== defaultLang) segments.push(langId);
  return `${base}/${segments.join('/')}`;
}

const homeHref     = buildHref(profile, lang);
const showcaseHref = section === 'showcase'
  ? Astro.url.pathname
  : `${base}/showcase`;

const langLinks = allLangs.map(l => ({
  id:     l.id,
  label:  l.label,
  href:   buildHref(profile, l.id),
  active: l.id === lang,
}));

const profileLinks = allProfiles.map(p => ({
  id:     p.id,
  label:  p.label,
  href:   buildHref(p.slug, lang),
  active: p.slug === profile,
}));

const currentYear = new Date().getFullYear();
const authorGit = 'https://github.com/KeeGooRoomiE/cv_hub';
---

<!doctype html>
<html lang={lang} data-base={base}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={metaImage} />
    <meta property="og:locale" content={t('meta.locale')} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={metaImage} />

    <script is:inline>
      const params = new URLSearchParams(window.location.search);
      const theme = params.get('theme');
      const allowed = ['frosted', 'light', 'nordic', 'peachy'];
      if (theme && allowed.includes(theme)) {
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = `${document.documentElement.dataset.base}/themes/${theme}.css`;
        document.addEventListener('DOMContentLoaded', () => {
          document.head.appendChild(link);
        });
      }
    </script>
  </head>
  <body>
    <AnimatedBackground />
    <header class="header">
      <div class="container header__row">
        <a class="brand" href={homeHref}>CV Hub</a>

        <nav class="nav">
          <a href={homeHref}>{t('nav.home')}</a>

          {profileLinks.length > 1 && (
            <div class="dropdown">
              <button class="dropdown__trigger" class:list={[{ active: true }]}>
                {t('nav.role')} ▾
              </button>
              <ul class="dropdown__menu">
                {profileLinks.map(p => (
                  <li>
                    <a href={p.href} class={p.active ? 'active' : ''}>
                      {p.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <a href={showcaseHref}>{t('nav.showcase')}</a>
        </nav>

        <div class="lang">
          {langLinks.map(l => (
            <a class={l.active ? 'active' : ''} href={l.href}>{l.label}</a>
          ))}
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container footer__inner">
        <span>© {currentYear}</span>
        <a href={authorGit} target="_blank" rel="noopener" class="footer__link">
          GitHub
        </a>
      </div>
    </footer>
  </body>
</html>