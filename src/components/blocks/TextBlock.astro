---
//
//  blocks/TextBlock.astro
//  CV Hub — Text block
//
//  All fields optional. Renders only what's present.
//

const { title, subtitle, body, bullets = [], links = [] } = Astro.props;

const hasContent = title || subtitle || body || bullets.length > 0 || links.length > 0;
if (!hasContent) return;
---

<div class="text-block">
  {title    && <h2 class="text-block__title">{title}</h2>}
  {subtitle && <p  class="text-block__subtitle">{subtitle}</p>}
  {body     && <p  class="text-block__body">{body}</p>}

  {bullets.length > 0 && (
    <ul class="text-block__bullets">
      {bullets.map((b: string) => <li>{b}</li>)}
    </ul>
  )}

  {links.filter((l: any) => l?.url).length > 0 && (
    <div class="text-block__links">
      {links.filter((l: any) => l?.url).map((l: any) => (
        <a class="link" href={l.url} target="_blank" rel="noopener">{l.label}</a>
      ))}
    </div>
  )}
</div>

<style>
  .text-block {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .text-block__title {
    margin: 0;
    font-size: 20px;
    font-weight: 700;
    color: var(--text);
  }

  .text-block__subtitle {
    margin: 0;
    font-size: 14px;
    color: var(--muted);
  }

  .text-block__body {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
    white-space: pre-wrap;
  }

  .text-block__bullets {
    margin: 0;
    padding-left: 20px;
    color: var(--muted);
    line-height: 1.7;
  }

  .text-block__bullets li {
    margin-bottom: 4px;
  }

  .text-block__bullets li::marker {
    color: var(--accent);
  }

  .text-block__links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
</style>